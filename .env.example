NODE_ENV=development

PORT=8080

# Local: mongodb://localhost:27017/echo
# Docker Compose overrides this to mongodb://mongo:27017/echo
MONGODB_URI=mongodb://localhost:27017/echo

JWT_SECRET=replace_this

ADMIN_USERNAME=admin

ADMIN_PASSWORD_HASH=

EMAIL_PROVIDER_API_KEY=

RATE_LIMIT_WINDOW=60000

RATE_LIMIT_MAX=100

VISITOR_HASH_SALT=replace_this_with_a_long_random_salt
COOKIE_SIGNING_SECRET=replace_this_with_a_long_random_cookie_signing_secret
FRONTEND_URL=http://localhost:3000

# Mongo Express (Docker only)
MONGO_EXPRESS_PORT=8081
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=admin